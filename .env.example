# IMPORTANT: This is a sample environment file.
# Copy this file to '.env' and update the values for your environment.
# Do not commit real credentials to version control.

# Application environment
NODE_ENV=development
PORT=4000

# -----------------------------------------------------------------------------
# Database connection
# -----------------------------------------------------------------------------
# The application supports explicit DB variables first. This is the preferred
# option, especially for Azure SQL Server or local MariaDB/MySQL.
# Use DB_DIALECT to select the correct Sequelize dialect.

# Example for local MariaDB/MySQL:
# DB_DIALECT=mariadb
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=radio_db
# DB_USER=chendo
# DB_PASSWORD=chendo123

# Example for Azure SQL Server:
DB_DIALECT=mssql
DB_HOST=your-sql-server.database.windows.net
DB_PORT=1433
DB_NAME=database_name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# Optional fallback single URL format (use only if you prefer a single connection string).
# Supported formats:
# - mysql://user:pass@host:port/database
# - mssql://user:pass@host:port/database
#DATABASE_URL=

# -----------------------------------------------------------------------------
# Security and tokens
# -----------------------------------------------------------------------------
JWT_SECRET=yourjwtsecret

# -----------------------------------------------------------------------------
# Frontend / Backend URLs
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Zeno FM / Radio configuration
# -----------------------------------------------------------------------------
# Get your Station ID and Stream ID from https://zeno.fm/
ZENO_STATION_ID=your_station_id
ZENO_STREAM_ID=your_stream_id

# -----------------------------------------------------------------------------
# Email configuration
# -----------------------------------------------------------------------------
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your-email-user
EMAIL_PASS=your-email-password